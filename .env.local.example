# Skeptr environment. Copy to .env.local and fill in. Never commit real keys.

# DeepSeek (LLM reasoning — gate + verdict)
DEEPSEEK_API_KEY=
# Optional: override the model (default deepseek-chat)
# LLM_MODEL=deepseek-chat

# Wire API (web evidence — Anakin Universal Scraper)
WIRE_API_KEY=
# Optional: override Wire base URL (default https://api.anakin.io)
# WIRE_BASE_URL=https://api.anakin.io

# Note: screenshot OCR runs locally via tesseract.js — no API key needed.
